# 金狗雷达后端
RADAR_BASE_URL=http://127.0.0.1:11800
RADAR_USERNAME=your_username
RADAR_PASSWORD=your_password
# 采集的链（逗号分隔，gmgn 短码：sol,eth,bsc,base）
RADAR_CHAINS=sol,eth,bsc
# 发现循环间隔（秒）
DISCOVER_INTERVAL=5
# 价格刷新循环间隔（秒）
PRICE_INTERVAL=60
# 每个币追踪时长（小时）
TRACK_HOURS=24
# SQLite 文件
DB_PATH=./radar.db
# gmgn-cli 可执行名
GMGN_CLI=gmgn-cli
# 看板端口
API_PORT=8000
